        APIM["API Management<br/>governed exposure"]
    end

    subgraph SRC["Sources"]
        S4["SAP S/4HANA<br/>Entity-APAC"]
        LOG["Logistics Tracker<br/>(webhook)"]
        WMS["WMS<br/>(REST API)"]
        PORT["Port Advisories<br/>(RSS / Email)"]
    end

    S4 --> RF --> DSP
    LOG --> EM --> DSP
    WMS --> IF --> DSP
    PORT --> IF --> DSP
    DSP --> SEM
    SEM --> APIM
    SEM --> SAC
